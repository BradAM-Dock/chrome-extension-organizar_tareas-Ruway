  {
    "manifest_version": 3,
    "name": "Ruway - Organizador de tareas",
    "version": "1.0",
    "description": "Ruway es un gestor de tareas simple pero poderoso integrado directamente en tu navegador.",
    "icons": {
      "16": "images/icon-16.png"
    },
    "action": {
      "default_popup": "popup/popup.html",
      "default_icon": "images/icon-16.png"
    },
    "background": {
      "service_worker": "scripts/background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["scripts/content.js"]
      }
    ],
    "permissions": [
      "storage",
      "activeTab"
    ]
  }